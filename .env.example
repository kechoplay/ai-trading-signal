# ========== AI TRADING SIGNAL — Node.js ==========

# Database (MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/ai_trading_signal"

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# ─── Market Data ───────────────────────────────────────
# Provider: twelvedata | oanda
MARKET_PROVIDER=twelvedata

# Instrument — phải khớp với provider đang dùng:
#   TwelveData : XAU/USD
TRADING_INSTRUMENT=XAU/USD
TRADING_TIMEFRAMES=H4,H1,M15,M5
# Bộ khung riêng cho crypto (entry từ M15 — bỏ M5 vì crypto nhiễu hơn vàng).
# Áp dụng khi instrument là crypto và request không truyền timeframes riêng.
TRADING_CRYPTO_TIMEFRAMES=D,H4,H1,M15
# Số nến tính FACTS cho từng khung crypto (D context, H4 bias, H1 POI, M15 entry).
TRADING_CRYPTO_CANDLES_D=90
TRADING_CRYPTO_CANDLES_H4=120
TRADING_CRYPTO_CANDLES_H1=180
TRADING_CRYPTO_CANDLES_M15=200
# Số nến thô gửi model cho khung entry crypto (M15). Vàng (M5) dùng CLAUDE_RAW_CANDLES.
CLAUDE_RAW_CANDLES_CRYPTO=40
TRADING_CANDLES_COUNT=214
TRADING_CANDLES_H4=30
TRADING_CANDLES_H1=214
TRADING_CANDLES_M15=240
TRADING_CANDLES_M5=180
TRADING_CANDLES_M1=240
TRADING_MIN_RR=2.0

# Scalp tốc độ cao (nút "Scalp XAU"): M15 context nhẹ → M5 khung chính → M1 entry.
TRADING_SCALP_TIMEFRAMES=M15,M5,M1

# Market hours — phân tích chỉ chạy trong giờ mở cửa
MARKET_HOURS_OPEN=6
MARKET_HOURS_CLOSE=22
MARKET_HOURS_TIMEZONE=Asia/Ho_Chi_Minh

# ─── TwelveData ────────────────────────────────────────
# Đăng ký miễn phí: https://twelvedata.com (800 req/ngày)
TWELVEDATA_API_KEY=
TWELVEDATA_BASE_URL=https://api.twelvedata.com

# ─── Binance Futures (sentiment cho crypto) ────────────
# API public, KHÔNG cần key. Cấp funding rate + open interest + BTC context cho
# phân tích crypto. Fail-soft: nếu lỗi/geo-block thì bỏ qua phần sentiment.
BINANCE_FAPI_BASE_URL=https://fapi.binance.com
# Đặt 'false' để tắt hoàn toàn (không gọi Binance, không lấy BTC context).
CRYPTO_FUTURES_SENTIMENT=true

# ─── Anthropic Claude ──────────────────────────────────
# Lấy API key: https://console.anthropic.com
# claude-opus-4-7    : mạnh nhất (mặc định)
# claude-sonnet-4-6  : nhanh hơn, rẻ hơn
# claude-haiku-4-5   : nhanh nhất, rẻ nhất
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# Độ sâu suy luận: low | medium | high | max (Sonnet 4.6 / Opus 4.x).
# Code đã tính sẵn ICT facts nên bài toán nhẹ → 'medium' cân bằng tốc độ/chất lượng.
CLAUDE_EFFORT=medium
# Số nến thô gửi cho khung entry (M5/H4). Các khung khác chỉ gửi facts đã tính sẵn.
CLAUDE_RAW_CANDLES=60
# Số nến thô THEO KHUNG cho intraday vàng (prompt v3.1) — model cần hình dạng nến ở
# nhiều khung: nhóm A/B/C của H1 (hold dài), "nến M15 thân lớn" (Cổng 2.5), impulsive
# leg M5. H4 không có → chỉ gửi facts. Tùy chọn: bỏ trống = dùng default bên dưới.
CLAUDE_RAW_CANDLES_H1=40
CLAUDE_RAW_CANDLES_M15=20
CLAUDE_RAW_CANDLES_M5=60

# ─── Telegram Bot ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DISCUSSION_ID=

# ─── API Server ────────────────────────────────────────
PORT=3000
# Đặt key bất kỳ để bảo vệ POST /api/analyze (để trống = public)
API_SERVER_KEY=

APP_DOMAIN=