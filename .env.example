APP_NAME="AI Trading Signal"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Asia/Ho_Chi_Minh

APP_LOCALE=vi
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ai_trading_signal
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ========== AI TRADING SIGNAL CONFIG ==========

# Market data provider: twelvedata | oanda
MARKET_PROVIDER=twelvedata

# Trading instrument — phải khớp với provider đang dùng:
#   TwelveData : XAU/USD
#   OANDA      : XAU_USD
TRADING_INSTRUMENT=XAU/USD
TRADING_TIMEFRAMES=M5,M15
TRADING_CANDLES_COUNT=100
TRADING_MIN_RR=2.0
TRADING_LANGUAGE=vi

# TwelveData API (đăng ký miễn phí tại https://twelvedata.com)
TWELVEDATA_API_KEY=

# OANDA API (không bắt buộc — dùng nếu có tài khoản)
OANDA_ENV=practice
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=

# ---- TradingView Screenshot (dùng khi MARKET_PROVIDER=tradingview) ----
TV_SYMBOL=OANDA:XAUUSD
TV_THEME=dark
TV_TIMEZONE=Asia/Ho_Chi_Minh
TV_WIDTH=1280
TV_HEIGHT=720
# Thời gian chờ chart render (ms) — tăng nếu vẫn bị ảnh trắng
TV_WAIT_MS=8000
TV_NODE_BINARY=
TV_NPM_BINARY=
# Lưu ảnh vào storage/app/screenshots/ để debug
TV_SAVE_SCREENSHOTS=true

# ---- Google Gemini (AI provider chính) ----
# Đăng ký API key miễn phí tại: https://aistudio.google.com
# gemini-2.0-flash : 1500 req/ngày, hỗ trợ vision (mặc định)
# gemini-1.5-pro   : chất lượng cao hơn, 50 req/ngày
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
