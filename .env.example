# ========== AI TRADING SIGNAL — Node.js ==========

# Database (SQLite)
DATABASE_URL="file:./prisma/data.db"

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# ─── Market Data ───────────────────────────────────────
# Provider: twelvedata | oanda
MARKET_PROVIDER=twelvedata

# Instrument — phải khớp với provider đang dùng:
#   TwelveData : XAU/USD
TRADING_INSTRUMENT=XAU/USD
TRADING_TIMEFRAMES=M5,M15,H1
TRADING_CANDLES_COUNT=214
TRADING_MIN_RR=2.0

# Market hours — phân tích chỉ chạy trong giờ mở cửa
MARKET_HOURS_OPEN=6
MARKET_HOURS_CLOSE=22
MARKET_HOURS_TIMEZONE=Asia/Ho_Chi_Minh

# ─── TwelveData ────────────────────────────────────────
# Đăng ký miễn phí: https://twelvedata.com (800 req/ngày)
TWELVEDATA_API_KEY=
TWELVEDATA_BASE_URL=https://api.twelvedata.com

# ─── Google Gemini ─────────────────────────────────────
# Đăng ký miễn phí: https://aistudio.google.com
# gemini-2.0-flash       : 1500 req/ngày (mặc định)
# gemini-2.5-flash-lite  : nhanh hơn, miễn phí
# gemini-1.5-pro         : chất lượng cao, 50 req/ngày
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Telegram Bot ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DISCUSSION_ID=
