generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Symbol {
  id          Int       @id @default(autoincrement())
  symbol      String    @unique
  name        String
  enabled     Boolean   @default(true)
  favorite    Boolean   @default(false)
  created_at  DateTime  @default(now())

  analyses    AnalysisLog[]

  @@map("symbols")
}

model AnalysisLog {
  id            Int      @id @default(autoincrement())
  symbol        String
  analyzed_at   DateTime @default(now())
  duration_ms   Int
  setup         String?
  reasoning     String?

  symbolRef     Symbol   @relation(fields: [symbol], references: [symbol])

  @@index([symbol, analyzed_at])
  @@map("analysis_logs")
}

model TradingSignal {
  id                  Int       @id @default(autoincrement())
  instrument          String
  action              String
  timeframe           String?
  entry               Float?
  stop_loss           Float?
  take_profit         Float?
  risk_reward         Float?
  confidence          Int?
  current_price       Float?
  reasoning           String?
  trend_bias          String?
  raw_ai_response     String?
  indicators_snapshot String?
  telegram_message_id String?
  sent_at             DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@index([instrument, created_at])
  @@map("trading_signals")
}
